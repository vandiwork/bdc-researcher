# Normalize line endings on commit; check out native-style on each platform.
* text=auto eol=lf

# Force LF for scripts/configs (run inside CI on Linux)
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
